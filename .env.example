# AI provider config for the two audit LLM calls (rubric scoring + rewrite
# generation). Two ways to configure it:
#
# 1. Simplest — set ANTHROPIC_API_KEY alone. Uses the real Anthropic API
#    with the built-in per-tier models (Haiku for scoring, Sonnet for
#    rewrites). This is the default production config; no other var needed.
ANTHROPIC_API_KEY=

# 2. Flexible — set AI_PROVIDER to pick any provider instead:
#      AI_PROVIDER=anthropic          - Anthropic direct or an
#                                        Anthropic-compatible proxy
#      AI_PROVIDER=openai-compatible  - any OpenAI-compatible chat/completions
#                                        endpoint: OpenRouter, zenmuz.ai,
#                                        Ollama (OpenAI-compat mode), vLLM,
#                                        LiteLLM, and most others
#    Together with:
#      AI_API_KEY   - the provider's key. For AI_PROVIDER=anthropic this
#                      falls back to ANTHROPIC_API_KEY if unset. For
#                      openai-compatible it's required (Ollama accepts any
#                      non-empty placeholder, e.g. "ollama").
#      AI_BASE_URL  - the endpoint base URL. Optional for AI_PROVIDER=anthropic
#                      (omit to use the real Anthropic API); required for
#                      openai-compatible, e.g. https://openrouter.ai/api/v1
#                      or http://localhost:11434/v1 for local Ollama.
#      AI_MODEL     - the model id to run, e.g. anthropic/claude-haiku-4.5
#                      (OpenRouter) or llama3.1 (Ollama). Used for BOTH the
#                      scoring and rewrite calls — a custom provider gets one
#                      model, not the built-in cheap/strong split. Optional
#                      for AI_PROVIDER=anthropic (defaults to the built-in ids).
# AI_PROVIDER=
# AI_API_KEY=
# AI_BASE_URL=
# AI_MODEL=

# Set to 1 to route every audit through the deterministic mock model
# (lib/audit/testModel.ts) instead of a real provider call — no key needed,
# zero cost. Used by the test suite; leave unset in production.
AUDIT_TEST_MOCK=
