# Server-side Anthropic key used for every audit's two LLM calls (rubric
# scoring + rewrite generation). No BYOK, no per-user keys — this is the
# ONLY provider credential v1 needs. Required in production (Vercel);
# omit locally and set AUDIT_TEST_MOCK=1 instead to run against the
# deterministic mock model.
ANTHROPIC_API_KEY=

# Set to 1 to route every audit through the deterministic mock model
# (lib/audit/testModel.ts) instead of a real Anthropic call — no key needed,
# zero cost. Used by the test suite; leave unset in production.
AUDIT_TEST_MOCK=
